<Window x:Class="HexToPcap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HexToPcap"
        Width="1120"
        Height="840"
        MinWidth="920"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#EAF5EC">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F5FBF6" Offset="0" />
            <GradientStop Color="#DDEEE0" Offset="1" />
        </LinearGradientBrush>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFFFB" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="BorderBrush" Value="#BFD5C4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2E6B4F" />
            <Setter Property="BorderBrush" Value="#2E6B4F" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#AFC6B5" />
            <Setter Property="Background" Value="#FDFEFD" />
            <Setter Property="Foreground" Value="#1F3327" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style x:Key="MenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="#F3FAF4" />
            <Setter Property="Foreground" Value="#284233" />
        </Style>
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource WindowBrush}">
        <Menu DockPanel.Dock="Top" Style="{StaticResource MenuStyle}">
            <Menu.Resources>
                <Style BasedOn="{StaticResource MenuItemStyle}" TargetType="MenuItem" />
            </Menu.Resources>
            <MenuItem Header="文件">
                <MenuItem Header="设置" Click="OnSettingsClick" />
                <Separator />
                <MenuItem Header="退出" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="使用说明" Click="OnHelpClick" />
            </MenuItem>
        </Menu>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1.7*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <TextBlock Text="HexToPcap"
                               VerticalAlignment="Center"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#1F3327" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#355342"
                               Text="输出目录" />
                    <Border Grid.Column="1"
                            Background="#F2F8F3"
                            BorderBrush="#C6D8CB"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,8">
                        <TextBox IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="14"
                                 Foreground="#1F3327"
                                 Text="{Binding OutputDirectory, Mode=OneWay}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#355342"
                               Text="十六进制输入" />
                    <TextBox x:Name="InputTextBox"
                             Grid.Row="1"
                             Margin="0,14,0,0"
                             MinHeight="380"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="15"
                             Style="{StaticResource InputBoxStyle}"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="0,0,0,16">
                <Button Content="转换并保存"
                        Width="150"
                        HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnConvertClick" />
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding SummaryText}"
                               TextWrapping="Wrap"
                               Foreground="#1F3327"
                               FontWeight="SemiBold" />
                    <ListView Grid.Row="1"
                              Margin="0,12,0,0"
                              BorderBrush="#BFD5C4"
                              ItemsSource="{Binding Errors}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="编号" Width="72" DisplayMemberBinding="{Binding Index}" />
                                <GridViewColumn Header="原因" Width="300" DisplayMemberBinding="{Binding Reason}" />
                                <GridViewColumn Header="原文片段" Width="650" DisplayMemberBinding="{Binding SourcePreview}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
