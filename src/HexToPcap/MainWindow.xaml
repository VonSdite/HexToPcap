<Window x:Class="HexToPcap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HexToPcap"
        Icon="Assets/HexToPcap.ico"
        Width="1120"
        Height="820"
        MinWidth="920"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#DEE6E0" />
        <SolidColorBrush x:Key="InputBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F6A4F" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#265640" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#F1F6F2" />
        <SolidColorBrush x:Key="TextBrush" Color="#1E2E24" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6A786F" />
        <SolidColorBrush x:Key="LineBrush" Color="#E9EEEA" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="MenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="2,1,0,1" />
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ReadOnlyPathTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="26,11" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#B8C6BE" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#B8C6BE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="#CCD8D0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E7EFEA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#F3F6F4" />
            <Setter Property="BorderBrush" Value="#E0E7E2" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EAF2ED" />
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F6FAF7" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EAF2ED" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource WindowBrush}">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource WindowBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,2,0,2">
            <Menu Style="{StaticResource MenuStyle}">
                <Menu.Resources>
                    <Style BasedOn="{StaticResource MenuItemStyle}" TargetType="MenuItem" />
                </Menu.Resources>
                <MenuItem Header="文件">
                    <MenuItem Header="退出" Click="OnExitClick" />
                </MenuItem>
                <MenuItem Header="帮助">
                    <MenuItem Header="使用说明" Click="OnHelpClick" />
                </MenuItem>
            </Menu>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource WindowBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,1,0,0">
            <StatusBar Background="Transparent"
                       BorderThickness="0"
                       Foreground="{StaticResource MutedTextBrush}">
                <StatusBarItem Padding="6,1">
                    <TextBlock FontSize="11"
                               Text="{Binding SummaryText}" />
                </StatusBarItem>
            </StatusBar>
        </Border>

        <Grid Margin="16,10,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="146" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextStyle}"
                               FontWeight="SemiBold"
                               Text="保存位置" />
                    <Border Grid.Column="1"
                            Margin="0,0,10,0"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="#D4E1D8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,10">
                        <TextBox IsReadOnly="True"
                                 Style="{StaticResource ReadOnlyPathTextBoxStyle}"
                                 Text="{Binding OutputDirectory, Mode=OneWay}" />
                    </Border>
                    <Button Grid.Column="2"
                            Content="设置"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OnSettingsClick" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="十六进制输入" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="支持普通 HEX 和 tcpdump -XX" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,16,0,0"
                            Background="{StaticResource InputBrush}"
                            BorderBrush="#CCD5CF"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBox x:Name="InputTextBox"
                                 MinHeight="390"
                                 VerticalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="2"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="Transparent"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True" />

            <Border Grid.Row="3"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   FontSize="14"
                                   Text="错误" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="仅显示解析失败项" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Background="{StaticResource InputBrush}"
                            BorderBrush="#D5DED8"
                            BorderThickness="1"
                            CornerRadius="10">
                        <DataGrid ItemsSource="{Binding Errors}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  RowHeaderWidth="0"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#E7ECE8"
                                  VerticalGridLinesBrush="#F0F3F1"
                                  AlternatingRowBackground="#FCFDFC"
                                  Background="Transparent"
                                  ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                                  CellStyle="{StaticResource DataGridCellStyle}"
                                  RowStyle="{StaticResource DataGridRowStyle}"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="60" />
                                <DataGridTextColumn Header="原因" Binding="{Binding Reason}" Width="220" />
                                <DataGridTextColumn Header="片段" Binding="{Binding SourcePreview}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="4" Margin="0,14,0,0">
                <Button Width="120"
                        HorizontalAlignment="Right"
                        Content="转换"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnConvertClick" />
            </Grid>
        </Grid>
    </DockPanel>
</Window>
