<Window x:Class="HexToPcap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HexToPcap"
        Icon="Assets/HexToPcap.ico"
        Width="1120"
        Height="820"
        MinWidth="920"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F9FBFA" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#F2F6F3" />
        <SolidColorBrush x:Key="TextBrush" Color="#1F2C24" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#67746D" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7E0DA" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#C4CFC8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F6A4F" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#265640" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EEF4F0" />

        <Style x:Key="MenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="2,1,0,1" />
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="ReadOnlyPathTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="26,10" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="#D2DDD5" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E5EEE8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel Background="{StaticResource WindowBrush}">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource WindowBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,2,0,2">
            <Menu Style="{StaticResource MenuStyle}">
                <Menu.Resources>
                    <Style BasedOn="{StaticResource MenuItemStyle}" TargetType="MenuItem" />
                </Menu.Resources>
                <MenuItem Header="文件">
                    <MenuItem Header="退出" Click="OnExitClick" />
                </MenuItem>
                <MenuItem Header="帮助">
                    <MenuItem Header="使用说明" Click="OnHelpClick" />
                </MenuItem>
            </Menu>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource WindowBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0">
            <StatusBar Background="Transparent"
                       BorderThickness="0"
                       Foreground="{StaticResource MutedTextBrush}">
                <StatusBarItem Padding="6,1">
                    <TextBlock FontSize="11"
                               Text="{Binding SummaryText}" />
                </StatusBarItem>
            </StatusBar>
        </Border>

            <Grid Margin="12,6,12,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="0,10,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextStyle}"
                               FontWeight="SemiBold"
                               Text="保存位置" />

                    <Border Grid.Column="1"
                            Margin="0,0,10,0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="12,9">
                        <TextBox IsReadOnly="True"
                                 Style="{StaticResource ReadOnlyPathTextBoxStyle}"
                                 Text="{Binding OutputDirectory, Mode=OneWay}" />
                    </Border>

                    <Button Grid.Column="2"
                            Content="设置"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OnSettingsClick" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource HeaderBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="十六进制输入" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="支持普通 HEX 和 tcpdump -XX" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="12"
                            Background="#FFFFFF"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1">
                        <TextBox x:Name="InputTextBox"
                                 MinHeight="410"
                                 VerticalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Button Width="120"
                        HorizontalAlignment="Right"
                        Content="转换"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnConvertClick" />
            </Grid>
        </Grid>
    </DockPanel>
</Window>
